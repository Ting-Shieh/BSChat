# Copy to .env and adjust
APP_NAME=BSChat API
DEBUG=true
# SEARCH_DEBUG_ENABLED=true  # optional; defaults off unless DEBUG=true
API_PORT=8001

DATABASE_URL=postgresql+asyncpg://bschat:bschat@localhost:5433/bschat
REDIS_URL=redis://localhost:6380/0

JWT_SECRET=dev-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Local: keep true. Dogfood/production: false
ALLOW_DEV_LOGIN=true
FRONTEND_BASE_URL=http://localhost:3000

# Google OAuth (optional locally)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback
# AUTH_EMAIL_DOMAIN_ALLOWLIST=yourcompany.com
# Email: Gmail SMTP (dogfood) and/or Resend (custom domain)
# EMAIL_PROVIDER=auto
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM_EMAIL=BSChat <you@gmail.com>
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=BSChat <noreply@yourdomain.com>
# DOGFOOD_DEFAULT_PLAN=pro

CORS_ORIGINS=http://localhost:3000
ENABLE_SWAGGER=true
API_BASE_URL=http://localhost:8001
# 媒體對外 URL（名片 /uploads）；Neon public_read 設成：
# https://<branch-id>.storage.c-N.us-east-2.aws.neon.tech/<bucket>
# STORAGE_PUBLIC_BASE_URL=https://br-xxx.storage.c-1.us-east-2.aws.neon.tech/bschat-cards

# Storage — local | neon | s3 | r2
# STORAGE_BACKEND=local
#
# Neon Object Storage (preferred for dogfood with Neon Postgres):
# STORAGE_BACKEND=neon
# AWS_ENDPOINT_URL_S3=https://br-xxx.storage.c-1.us-east-2.aws.neon.build
# AWS_ACCESS_KEY_ID=nak_live_...
# AWS_SECRET_ACCESS_KEY=nsk_live_...
# AWS_REGION=us-east-2
# S3_BUCKET_NAME=bschat-cards
# STORAGE_PUBLIC_BASE_URL=https://br-xxx.storage.c-1.us-east-2.aws.neon.tech/bschat-cards
#
# Cloudflare R2 (optional):
# STORAGE_BACKEND=r2
# R2_PUBLIC_URL=https://media.yourdomain.com
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# OCR — Gemini（推薦測試）
OCR_PROVIDER=gemini
OCR_USE_MOCK=false
# GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash

# Search (M5) — gemini | openai | claude | mock
# SEARCH_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_SEARCH_MODEL=gpt-4o-mini
# SEARCH_USE_MOCK=false

# OCR — Claude（備選）
# OCR_PROVIDER=claude
# ANTHROPIC_API_KEY=
# OCR_MODEL=claude-sonnet-4-20250514

# M3.5 person enrichment (Pro: LinkedIn API + LLM — API 串接後設 PERSON_SEARCH_PROVIDER=linkedin)
PERSON_SEARCH_PROVIDER=mock
# 有 GEMINI_API_KEY 時，mock 模式下會用 Google Search 查使用者提供的 LinkedIn URL（公開摘要）
# PERSON_LINKEDIN_WEB_FALLBACK=false
# 同步請求內 web 查詢逾時秒數（預設 20；補充為 request 內同步執行，勿設過高）
# PERSON_WEB_LOOKUP_TIMEOUT_S=20
