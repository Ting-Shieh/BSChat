# Copy to .env and adjust
APP_NAME=BSChat API
DEBUG=true
API_PORT=8001

DATABASE_URL=postgresql+asyncpg://bschat:bschat@localhost:5433/bschat
REDIS_URL=redis://localhost:6380/0

JWT_SECRET=dev-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000
ENABLE_SWAGGER=true
API_BASE_URL=http://localhost:8001

# OCR — Gemini（推薦測試）
OCR_PROVIDER=gemini
OCR_USE_MOCK=false
GEMINI_API_KEY=AIzaSyAh50u9znDTgHrtea1zBrmvDofBdnYNN5o
GEMINI_OCR_MODEL=gemini-2.5-flash

# OCR — Claude（備選）
# OCR_PROVIDER=claude
# ANTHROPIC_API_KEY=
# OCR_MODEL=claude-sonnet-4-20250514

# M3.5 person enrichment (Pro: LinkedIn API + LLM — API 串接後設 PERSON_SEARCH_PROVIDER=linkedin)
PERSON_SEARCH_PROVIDER=mock
# 有 GEMINI_API_KEY 時，mock 模式下會用 Google Search 查使用者提供的 LinkedIn URL（公開摘要）
