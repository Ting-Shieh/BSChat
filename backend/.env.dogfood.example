# Dogfood / staging — copy values into host dashboards.
# Do NOT commit real secrets.

APP_NAME=BSChat API
DEBUG=false
ENABLE_SWAGGER=true
USE_CELERY_WORKERS=false

DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DB?ssl=require
REDIS_URL=redis://default:PASS@HOST:6379

JWT_SECRET=replace-with-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

ALLOW_DEV_LOGIN=false
FRONTEND_BASE_URL=https://YOUR-SITE.netlify.app
DOGFOOD_DEFAULT_PLAN=pro

# Google OAuth (Cloud Console → Web client)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-API/api/v1/auth/google/callback

# Optional: only @yourcompany.com
# AUTH_EMAIL_DOMAIN_ALLOWLIST=yourcompany.com

# Auth + enterprise invitation email
# Prefer Gmail SMTP for dogfood (no custom domain). Resend when domain verified.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_EMAIL=BSChat <you@gmail.com>
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=BSChat <noreply@yourdomain.com>

CORS_ORIGINS=https://YOUR-SITE.netlify.app
API_BASE_URL=https://YOUR-API
API_PORT=8000

STORAGE_BACKEND=neon
# From Neon Console → branch → Credentials (storage:read + storage:write)
AWS_ENDPOINT_URL_S3=https://br-xxx.storage.c-1.us-east-2.aws.neon.build
AWS_ACCESS_KEY_ID=nak_live_...
AWS_SECRET_ACCESS_KEY=nsk_live_...
AWS_REGION=us-east-2
S3_BUCKET_NAME=bschat-cards
# public_read bucket URL = https://<branch-id>.storage.c-N.us-east-2.aws.neon.tech/<bucket>
STORAGE_PUBLIC_BASE_URL=https://br-xxx.storage.c-1.us-east-2.aws.neon.tech/bschat-cards

OCR_PROVIDER=gemini
OCR_USE_MOCK=false
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash

PERSON_SEARCH_PROVIDER=mock
SEARCH_USE_MOCK=false
SEARCH_EMBEDDING_ENABLED=true
