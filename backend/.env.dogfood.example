# Dogfood / staging — copy values into Railway / Vercel / Neon dashboards.
# Do NOT commit real secrets.

APP_NAME=BSChat API
DEBUG=false
ENABLE_SWAGGER=true
USE_CELERY_WORKERS=false

# Neon (or any Postgres with pgvector + pg_trgm)
# Format must use asyncpg driver:
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DB?ssl=require

# Upstash / Railway Redis (Celery app still reads this at import time)
REDIS_URL=redis://default:PASS@HOST:6379

JWT_SECRET=replace-with-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# After Vercel deploy, put the real frontend URL here (comma-separated OK)
CORS_ORIGINS=https://YOUR-APP.vercel.app

# Public API URL (Railway public domain)
API_BASE_URL=https://YOUR-API.up.railway.app
API_PORT=8000

# Card images: local disk is ephemeral on Railway — use R2 for dogfood
STORAGE_BACKEND=r2
STORAGE_PUBLIC_BASE_URL=https://YOUR-R2-PUBLIC-DOMAIN
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://YOUR-R2-PUBLIC-DOMAIN

OCR_PROVIDER=gemini
OCR_USE_MOCK=false
GEMINI_API_KEY=
GEMINI_OCR_MODEL=gemini-2.5-flash

PERSON_SEARCH_PROVIDER=mock
SEARCH_USE_MOCK=false
SEARCH_EMBEDDING_ENABLED=true
